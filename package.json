{
  "name": "no-code-red",
  "version": "0.1.0",
  "private": true,
  "description": "Node-RED plugin: prompt-driven flow generation via Claude CLI, with realtime canvas animation.",
  "license": "MIT",
  "engines": {
    "node": ">=20 <27"
  },
  "type": "module",
  "main": "dist/server/plugin.js",
  "node-red": {
    "plugins": {
      "no-code-red": "dist/server/plugin.js"
    },
    "nodes": {
      "postgres": "dist/server/nodes/postgres.js",
      "mariadb": "dist/server/nodes/mariadb.js",
      "oraclesql": "dist/server/nodes/oraclesql.js",
      "sqlite": "dist/server/nodes/sqlite.js",
      "mongodb": "dist/server/nodes/mongodb.js",
      "cassandra": "dist/server/nodes/cassandra.js",
      "clickhouse": "dist/server/nodes/clickhouse.js",
      "redis": "dist/server/nodes/redis.js",
      "elasticsearch": "dist/server/nodes/elasticsearch.js",
      "opensearch": "dist/server/nodes/opensearch.js",
      "neo4j": "dist/server/nodes/neo4j.js",
      "influxdb": "dist/server/nodes/influxdb.js",
      "etcd": "dist/server/nodes/etcd.js",
      "qdrant": "dist/server/nodes/qdrant.js",
      "weaviate": "dist/server/nodes/weaviate.js",
      "kafka-producer": "dist/server/nodes/kafka-producer.js",
      "kafka-consumer": "dist/server/nodes/kafka-consumer.js",
      "rabbitmq": "dist/server/nodes/rabbitmq.js",
      "nats": "dist/server/nodes/nats.js",
      "s3": "dist/server/nodes/s3.js",
      "graphql": "dist/server/nodes/graphql.js",
      "prometheus": "dist/server/nodes/prometheus.js",
      "scheduler": "dist/server/nodes/scheduler.js",
      "llm": "dist/server/nodes/llm.js",
      "window-aggregate": "dist/server/nodes/window-aggregate.js",
      "stream-join": "dist/server/nodes/stream-join.js",
      "pattern-match": "dist/server/nodes/pattern-match.js",
      "dedupe": "dist/server/nodes/dedupe.js",
      "gate": "dist/server/nodes/gate.js",
      "metronome": "dist/server/nodes/metronome.js",
      "schema": "dist/server/nodes/schema.js",
      "tracer": "dist/server/nodes/tracer.js",
      "query-table": "dist/server/nodes/query-table.js",
      "table-join": "dist/server/nodes/table-join.js",
      "liveview": "dist/server/nodes/liveview.js",
      "feed-sim": "dist/server/nodes/feed-sim.js",
      "filter": "dist/server/nodes/filter.js",
      "map": "dist/server/nodes/map.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && (test -d custom-nodes && find custom-nodes -name '*.ts' -print -quit | grep -q . && tsc -p tsconfig.custom-nodes.json || true) && node scripts/copy-assets.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "npm run build && node scripts/dev.mjs",
    "dev:rebuild": "npm run build"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "node-red": "^4.1.10",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@aws-sdk/client-s3": "^3.1051.0",
    "@clickhouse/client": "^1.18.5",
    "@elastic/elasticsearch": "^9.4.1",
    "@influxdata/influxdb-client": "^1.35.0",
    "@opensearch-project/opensearch": "^3.6.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "amqplib": "^2.0.1",
    "better-sqlite3": "^12.10.0",
    "cassandra-driver": "^4.9.0",
    "etcd3": "^1.1.2",
    "graphql-request": "^7.4.0",
    "kafkajs": "^2.2.4",
    "mariadb": "^3.5.2",
    "mongodb": "^7.2.0",
    "nats": "^2.29.3",
    "neo4j-driver": "^6.0.1",
    "oracledb": "^6.10.0",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "weaviate-client": "^3.13.0"
  }
}
